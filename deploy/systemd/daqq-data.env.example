# EnvironmentFile for daqq-data-push.service.
#
# WORKER_URL    the deployed Worker base (from `wrangler deploy`), no trailing /
# INGEST_TOKEN  the shared bearer token, identical to the Worker secret set with
#               `wrangler secret put INGEST_TOKEN`
#
# Install on the node with 600 perms (never commit the real file):
#   install -m 600 /dev/stdin /root/.daqq-data.env <<'EOF'
#   WORKER_URL=https://daqq-data.<you>.workers.dev
#   INGEST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#   EOF
WORKER_URL=
INGEST_TOKEN=
